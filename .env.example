# 工作路径（可选，默认当前工作目录下的 .knowledge-hub/）
# 短文本笔记存 .knowledge-hub/notes/（Claude Code 直接 Read）
# 长文本数据存 .knowledge-hub/rag/（local-rag 索引：ChromaDB、uploads、图谱）
# LOCAL_RAG_WORK_DIR=.knowledge-hub

# 嵌入模型
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# ChromaDB
CHROMA_COLLECTION_NAME=documents

# Neo4j 知识图谱
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ragpassword123

# LLM 实体提取（兼容 OpenAI API 格式，支持任意兼容模型）
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7

# 图谱实体提取
GRAPH_ENTITY_EXTRACTOR=jieba  # jieba（快速）或 llm（高质量）
GRAPH_MAX_ENTITIES=10
GRAPH_MAX_DEPTH=2

# 文本切分
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# 检索
TOP_K=4
BM25_ENABLED=true

# OCR
OCR_LANGUAGES=ch,en
OCR_DPI=200
